<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.CommentInfoMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.CommentInfo">
        SELECT 
            comment_info.*,
            CASE 
                WHEN comment_info.type_code = 'SCENIC' THEN scenic_info.name
                WHEN comment_info.type_code = 'TRAVEL_NOTE' THEN travel_note.title
                ELSE NULL
            END AS associationName
        FROM comment_info
        LEFT JOIN scenic_info ON comment_info.type_code = 'SCENIC' AND comment_info.association_id = scenic_info.id
        LEFT JOIN travel_note ON comment_info.type_code = 'TRAVEL_NOTE' AND comment_info.association_id = travel_note.id
        LEFT JOIN user ON comment_info.user_id = user.id
        <include refid="queryConditions"/>
        ORDER BY comment_info.create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(comment_info.id) FROM comment_info
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
            <if test="query.name != null and query.name.trim() != ''">
                AND comment_info.name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.typeCode != null and query.typeCode.trim() != ''">
                AND comment_info.type_code = #{query.typeCode}
            </if>
            <if test="query.content != null and query.content.trim() != ''">
                AND comment_info.content LIKE CONCAT('%', #{query.content}, '%')
            </if>
            <if test="query.userName != null and query.userName.trim() != ''">
                AND user.username LIKE CONCAT('%', #{query.userName}, '%')
            </if>
            <if test="query.associationId != null">
                AND comment_info.association_id = #{query.associationId}
            </if>
            <if test="query.parentStatus != null">
                AND comment_info.parent_id is null
            </if>
        </where>
    </sql>
    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.CommentInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comment_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="typeCode != null">type_code,</if>
            <if test="associationId != null">association_id,</if>
            <if test="content != null">content,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="typeCode != null">#{typeCode},</if>
            <if test="associationId != null">#{associationId},</if>
            <if test="content != null">#{content},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.CommentInfo">
        UPDATE comment_info
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="typeCode != null">
                type_code = #{typeCode},
            </if>
            <if test="associationId != null">
                association_id = #{associationId},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="parentId != null">
                parent_id = #{parentId},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM comment_info
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 获取统计数据 -->
    <select id="getStatistics" resultType="map">
        SELECT 
            COUNT(*) as total,
            SUM(CASE WHEN DATE(create_time) = CURDATE() THEN 1 ELSE 0 END) as todayCount,
            SUM(CASE WHEN type_code = 'SCENIC' THEN 1 ELSE 0 END) as scenicCount,
            SUM(CASE WHEN type_code = 'TRAVEL_NOTE' THEN 1 ELSE 0 END) as noteCount
        FROM comment_info
    </select>
</mapper>
