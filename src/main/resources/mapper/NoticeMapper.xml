<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.NoticeMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.Notice">
        SELECT notice.*
        FROM notice
        <include refid="queryConditions"/>
        ORDER BY notice.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(notice.id) FROM notice
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
            <!-- 管理员权限：可以查看所有通知 -->
            <if test="query.isAdmin == null or query.isAdmin == false">
                <!-- 用户ID过滤：所有通知都是私有的，必须匹配用户ID -->
                <if test="query.userId != null">
                    <choose>
                        <!-- 游客（userId = -1 或 isGuest = true）：不返回任何通知 -->
                        <when test="query.userId == -1 or query.isGuest == true">
                            AND 1 = 0
                        </when>
                        <!-- 普通用户：只查看自己的通知 -->
                        <otherwise>
                            AND notice.user_id = #{query.userId}
                        </otherwise>
                    </choose>
                </if>
            </if>
            <!-- 已读状态过滤 -->
            <if test="query.isRead != null and query.isRead.trim() != ''">
                AND notice.is_read = #{query.isRead}
            </if>
            <!-- 通知类型过滤 -->
            <if test="query.typeCode != null and query.typeCode.trim() != ''">
                AND notice.type_code = #{query.typeCode}
            </if>
            <!-- 标题搜索 -->
            <if test="query.title != null and query.title.trim() != ''">
                AND notice.title LIKE CONCAT('%', #{query.title}, '%')
            </if>
            <!-- 内容搜索 -->
            <if test="query.content != null and query.content.trim() != ''">
                AND notice.content LIKE CONCAT('%', #{query.content}, '%')
            </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.Notice" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            user_id,
            <if test="title != null">title,</if>
            <if test="content != null">content,</if>
            <if test="isRead != null">is_read,</if>
            <if test="createTime != null">create_time,</if>
            <if test="typeCode != null">type_code,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            #{userId},
            <if test="title != null">#{title},</if>
            <if test="content != null">#{content},</if>
            <if test="isRead != null">#{isRead},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="typeCode != null">#{typeCode},</if>
        </trim>


    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.Notice">
        UPDATE notice
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="isRead != null">
                is_read = #{isRead},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
            <if test="typeCode != null">
                type_code = #{typeCode},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM notice
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
