<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.RouteMapper">

    <resultMap id="RouteWithUserMap" type="com.project.platform.entity.Route">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="cover" property="cover"/>
        <result column="days" property="days"/>
        <result column="total_cost" property="totalCost"/>
        <result column="view_count" property="viewCount"/>
        <result column="likes_count" property="likesCount"/>
        <result column="comments_count" property="commentsCount"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <association property="user" javaType="com.project.platform.entity.User">
            <id column="user_id" property="id"/>
            <result column="username" property="username"/>
            <result column="avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <select id="selectRoutePage" resultMap="RouteWithUserMap">
        SELECT
        r.*,
        u.username,
        u.avatar_url,
        (SELECT COUNT(*) FROM likes l WHERE l.association_id = r.id AND l.type_code = '路线分享') as likes_count,
        (SELECT COUNT(*) FROM comment_info c WHERE c.association_id = r.id AND c.type_code = '游记') as comments_count
        FROM route r
        LEFT JOIN user u ON r.user_id = u.id
        WHERE r.status = 'published'
        <if test="title != null and title != ''">
            AND r.title LIKE CONCAT('%', #{title}, '%')
        </if>
        ORDER BY r.create_time DESC
    </select>

    <select id="selectWithUserById" resultMap="RouteWithUserMap">
        SELECT
            r.*,
            u.username,
            u.avatar_url
        FROM route r
                 LEFT JOIN user u ON r.user_id = u.id
        WHERE r.id = #{id}
    </select>


    <select id="queryPage" resultType="com.project.platform.entity.Route">
        SELECT route.*
        FROM route
        LEFT JOIN user u ON route.user_id = u.id
        <include refid="queryConditions"/>
        ORDER BY route.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="queryCount" resultType="int">
        SELECT count(route.id) 
        FROM route
        LEFT JOIN user u ON route.user_id = u.id
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
            <if test="query.userId != null">
                AND route.user_id = #{query.userId}
            </if>
            <if test="query.userName != null and query.userName.trim() != ''">
                AND u.username LIKE CONCAT('%', #{query.userName}, '%')
            </if>
            <if test="query.title != null and query.title.trim() != ''">
                AND route.title LIKE CONCAT('%', #{query.title}, '%')
            </if>
            <if test="query.description != null and query.description.trim() != ''">
                AND route.description LIKE CONCAT('%', #{query.description}, '%')
            </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.Route" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO route
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="title != null">title,</if>
            <if test="description != null">description,</if>
            <if test="cover != null">cover,</if>
            <if test="days != null">days,</if>
            <if test="totalCost != null">total_cost,</if>
            <if test="content != null">content,</if>
            <if test="status != null">status,</if>
            create_time, update_time
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="title != null">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="cover != null">#{cover},</if>
            <if test="days != null">#{days},</if>
            <if test="totalCost != null">#{totalCost},</if>
            <if test="content != null">#{content},</if>
            <if test="status != null">#{status},</if>
            NOW(), NOW()
        </trim>
    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.Route">
        UPDATE route
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="cover != null">cover = #{cover},</if>
            <if test="days != null">days = #{days},</if>
            <if test="totalCost != null">total_cost = #{totalCost},</if>
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM route
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>