<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.ViewHistoryMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.ViewHistory">
        SELECT view_history.*
        FROM view_history
        <include refid="queryConditions"/>
        ORDER BY view_history.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(view_history.id) FROM view_history
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
            <if test="query.type != null  and query.type.trim() != ''">
                AND view_history.type_code = #{query.type}
            </if>
            <if test="query.userId != null">
                AND view_history.user_id =  #{query.userId}
            </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.ViewHistory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO view_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="typeCode != null">type_code,</if>
            <if test="userId != null">user_id,</if>
            <if test="associationId != null">association_id,</if>
            <if test="viewTime != null">view_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="typeCode != null">#{typeCode},</if>
            <if test="userId != null">#{userId},</if>
            <if test="associationId != null">#{associationId},</if>
            <if test="viewTime != null">#{viewTime},</if>
        </trim>


    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.ViewHistory">
        UPDATE view_history
        <set>
            <if test="type != null">
                type_code = #{typeCode},
            </if>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="associationId != null">
                association_id = #{associationId},
            </if>
            <if test="viewTime != null">
                view_time = #{viewTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM view_history
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
